{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pomodoro Overlay",
  "version": "0.3.7",
  "identifier": "com.sirbepy.pomodoro-overlay",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "url": "index.html",
        "title": "Pomodoro Overlay",
        "width": 280,
        "height": 80,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "maximizable": false,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "publisher": "SirBepy"
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/SirBepy/pomodoro-overlay/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFGOTY2MjUzMEVCMTZFNjkKUldScGJyRU9VMktXcjdlTXBmdURZcDFHaHViL0R5VkxKQU53ajFUU3NWdzcrRGFMU2RUYlNmbmEK",
      "dialog": false
    }
  }
}
